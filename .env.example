# Pype Web - Environment Configuration
# Copy this file to .env and customize values
# 
# ⚠️ IMPORTANT: This project uses RUNTIME CONFIGURATION
# You can change these values and restart the container WITHOUT rebuilding
# See RUNTIME_CONFIG.md for detailed instructions

# ============================================
# NODE.JS & APP CONFIGURATION
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# API CONFIGURATION
# ============================================
# Backend API URL
# This value is read at runtime, not build time
# Examples:
#   - Development: http://localhost:8080
#   - Docker Compose: http://pype-admin:8080
#   - Azure: https://pype-admin.azurewebsites.net
#   - On-premise: http://internal-api-server:8080
PYPE_API_URL=http://pype-admin:8080
