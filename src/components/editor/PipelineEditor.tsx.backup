'use client';

import { useState, useEffect } from 'react';
import { useRouter } from 'next/navigation';
import { useForm } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';
import * as z from 'zod';
import YamlEditor from '@/components/editor/YamlEditor';
import FileUpload from '@/components/editor/FileUpload';
import ValidationResults from '@/components/editor/ValidationResults';
import ComponentConfigModal from '@/components/editor/ComponentConfigModal';
import PipelineFormBuilder from '@/components/form-builder/PipelineFormBuilder';
import TestFormBuilder from '@/components/form-builder/TestFormBuilder';
import { PIPELINE_TEMPLATES, TemplateType } from '@/constants/pipelineTemplates';
import { pipelineService } from '@/services/pipelineService';
import { CreatePipelineRequest } from '@/types';
import { DocumentIcon, CodeBracketIcon, PlayIcon, ArrowLeftIcon, WrenchScrewdriverIcon, PlusIcon, PencilIcon, TrashIcon, XMarkIcon } from '@heroicons/react/24/outline';

const pipelineSchema = z.object({
  name: z.string().min(1, 'Nome é obrigatório').max(100, 'Nome muito longo'),
  description: z.string().optional(),
  isActive: z.boolean().default(true),
  cronExpression: z.string().optional(),
  tags: z.string().optional(),
});

type PipelineFormData = z.infer<typeof pipelineSchema>;

interface PipelineEditorProps {
  pipelineId?: string; // Para modo de edição
}

export default function PipelineEditor({ pipelineId }: PipelineEditorProps) {
  const router = useRouter();
  const [yamlContent, setYamlContent] = useState('');
  const [isValidYaml, setIsValidYaml] = useState(true);
  const [validationErrors, setValidationErrors] = useState<string[]>([]);
  const [selectedTemplate, setSelectedTemplate] = useState<TemplateType | ''>('');
  const [isLoading, setIsLoading] = useState(false);
  const [isSaving, setIsSaving] = useState(false);
  const [uploadedFileName, setUploadedFileName] = useState<string | null>(null);
  const [showPreview, setShowPreview] = useState(false);
  const [editorMode, setEditorMode] = useState<'yaml' | 'form'>('form'); // Default to form builder

  // Form Builder states
  const [pipeline, setPipeline] = useState<{
    sources?: Array<{ name: string; type: string; config?: any }>;
    transformers?: Array<{ name: string; type: string; config?: any }>;
    destinations?: Array<{ name: string; type: string; config?: any }>;
  }>({});
  
  const [showModal, setShowModal] = useState(false);
  const [modalType, setModalType] = useState<'source' | 'transformer' | 'destination' | null>(null);
  const [editingIndex, setEditingIndex] = useState<number | null>(null);

  const {
    register,
    handleSubmit,
    formState: { errors },
    setValue,
    watch,
  } = useForm<PipelineFormData>({
    resolver: zodResolver(pipelineSchema),
    defaultValues: {
      isActive: true,
    },
  });

  const isEditMode = !!pipelineId;

  // Pipeline component management functions
  const openAddModal = (type: 'source' | 'transformer' | 'destination') => {
    setModalType(type);
    setEditingIndex(null);
    setShowModal(true);
  };

  const editComponent = (type: 'source' | 'transformer' | 'destination', index: number) => {
    setModalType(type);
    setEditingIndex(index);
    setShowModal(true);
  };

  const removeComponent = (type: 'source' | 'transformer' | 'destination', index: number) => {
    setPipeline(prev => {
      const updated = { ...prev };
      if (type === 'source' && updated.sources) {
        updated.sources = updated.sources.filter((_, i) => i !== index);
      } else if (type === 'transformer' && updated.transformers) {
        updated.transformers = updated.transformers.filter((_, i) => i !== index);
      } else if (type === 'destination' && updated.destinations) {
        updated.destinations = updated.destinations.filter((_, i) => i !== index);
      }
      return updated;
    });
  };

  const addComponent = (type: 'source' | 'transformer' | 'destination', component: any) => {
    setPipeline(prev => {
      const updated = { ...prev };
      if (type === 'source') {
        updated.sources = [...(updated.sources || []), component];
      } else if (type === 'transformer') {
        updated.transformers = [...(updated.transformers || []), component];
      } else if (type === 'destination') {
        updated.destinations = [...(updated.destinations || []), component];
      }
      return updated;
    });
  };

  const updateComponent = (type: 'source' | 'transformer' | 'destination', index: number, component: any) => {
    setPipeline(prev => {
      const updated = { ...prev };
      if (type === 'source' && updated.sources) {
        updated.sources[index] = component;
      } else if (type === 'transformer' && updated.transformers) {
        updated.transformers[index] = component;
      } else if (type === 'destination' && updated.destinations) {
        updated.destinations[index] = component;
      }
      return updated;
    });
  };

  // Carregar pipeline para edição
  useEffect(() => {
    if (isEditMode && pipelineId) {
      loadPipeline(pipelineId);
    } else {
      // Modo criação - usar template básico
      setYamlContent(PIPELINE_TEMPLATES.basic);
    }
  }, [isEditMode, pipelineId]);

  // Sincronizar Form Builder com YAML
  useEffect(() => {
    if (editorMode === 'form' && (pipeline.sources || pipeline.transformers || pipeline.destinations)) {
      updateYamlFromFormBuilder();
    }
  }, [pipeline, editorMode]);

  const updateYamlFromFormBuilder = () => {
    const pipelineYaml = {
      name: watch('name') || 'Pipeline sem nome',
      description: watch('description') || '',
      sources: pipeline.sources || [],
      transformers: pipeline.transformers || [],
      destinations: pipeline.destinations || [],
      schedule: {
        cronExpression: watch('cronExpression') || '0 0 * * *'
      },
      metadata: {
        tags: watch('tags')?.split(',').map(t => t.trim()).filter(Boolean) || [],
        isActive: watch('isActive') !== false
      }
    };

    // Converter para YAML string (implementação simples)
    const yamlString = `name: "${pipelineYaml.name}"
description: "${pipelineYaml.description}"

sources:
${pipelineYaml.sources.map(source => `  - name: "${source.name}"
    type: "${source.type}"
    config:
${Object.entries(source.config || {}).map(([key, value]) => `      ${key}: "${value}"`).join('\n')}`).join('\n')}

transformers:
${pipelineYaml.transformers.map(transformer => `  - name: "${transformer.name}"
    type: "${transformer.type}"
    config:
${Object.entries(transformer.config || {}).map(([key, value]) => `      ${key}: "${value}"`).join('\n')}`).join('\n')}

destinations:
${pipelineYaml.destinations.map(destination => `  - name: "${destination.name}"
    type: "${destination.type}"
    config:
${Object.entries(destination.config || {}).map(([key, value]) => `      ${key}: "${value}"`).join('\n')}`).join('\n')}

schedule:
  cronExpression: "${pipelineYaml.schedule.cronExpression}"

metadata:
  tags: [${pipelineYaml.metadata.tags.map(tag => `"${tag}"`).join(', ')}]
  isActive: ${pipelineYaml.metadata.isActive}`;

    setYamlContent(yamlString);
  };

  const loadPipeline = async (id: string) => {
    try {
      setIsLoading(true);
      const pipeline = await pipelineService.getPipeline(id);
      
      // Preencher formulário
      setValue('name', pipeline.name);
      setValue('description', pipeline.description || '');
      setValue('isActive', pipeline.isActive);
      setValue('cronExpression', pipeline.cronExpression || '');
      setValue('tags', pipeline.tags?.join(', ') || '');
      
      // Carregar YAML
      setYamlContent(pipeline.yamlDefinition);
    } catch (error) {
      console.error('Erro ao carregar pipeline:', error);
      alert('Erro ao carregar pipeline');
      router.push('/dashboard/pipelines');
    } finally {
      setIsLoading(false);
    }
  };

  const handleTemplateSelect = (template: TemplateType) => {
    setSelectedTemplate(template);
    setYamlContent(PIPELINE_TEMPLATES[template]);
    setUploadedFileName(null);
  };

  const handleFileUpload = (content: string, filename: string) => {
    setYamlContent(content);
    setUploadedFileName(filename);
    setSelectedTemplate('');
  };

  const handleValidationChange = (isValid: boolean, errors: string[]) => {
    setIsValidYaml(isValid);
    setValidationErrors(errors);
  };

  const onSubmit = async (data: PipelineFormData) => {
    if (!isValidYaml) {
      alert('Por favor, corrija os erros de validação antes de salvar.');
      return;
    }

    if (!yamlContent.trim()) {
      alert('O conteúdo YAML é obrigatório.');
      return;
    }

    setIsSaving(true);

    try {
      const pipelineData: CreatePipelineRequest = {
        name: data.name,
        description: data.description,
        yamlDefinition: yamlContent,
        isActive: data.isActive,
        cronExpression: data.cronExpression || undefined,
        tags: data.tags ? data.tags.split(',').map(t => t.trim()).filter(t => t) : undefined,
      };

      if (isEditMode && pipelineId) {
        await pipelineService.updatePipeline(pipelineId, pipelineData);
        alert('Pipeline atualizado com sucesso!');
      } else {
        await pipelineService.createPipeline(pipelineData);
        alert('Pipeline criado com sucesso!');
      }

      router.push('/dashboard/pipelines');
    } catch (error: any) {
      console.error('Erro ao salvar pipeline:', error);
      alert(`Erro ao salvar pipeline: ${error.message || 'Erro desconhecido'}`);
    } finally {
      setIsSaving(false);
    }
  };

  const handleTestRun = async () => {
    if (!isEditMode || !pipelineId) {
      alert('Pipeline deve ser salvo antes de executar um teste.');
      return;
    }

    try {
      await pipelineService.runPipeline(pipelineId);
      alert('Execução de teste iniciada! Verifique o status na lista de pipelines.');
    } catch (error: any) {
      console.error('Erro ao executar pipeline:', error);
      alert(`Erro ao executar pipeline: ${error.message || 'Erro desconhecido'}`);
    }
  };

  if (isLoading) {
    return (
      <div className="flex items-center justify-center h-64">
        <div className="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
        <span className="ml-2">Carregando pipeline...</span>
      </div>
    );
  }

  return (
    <div className="space-y-6">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div className="flex items-center space-x-4">
          <button
            onClick={() => router.push('/dashboard/pipelines')}
            className="p-2 text-gray-400 hover:text-gray-600 transition-colors"
          >
            <ArrowLeftIcon className="h-5 w-5" />
          </button>
          <div>
            <h1 className="text-2xl font-bold text-gray-900">
              {isEditMode ? 'Editar Pipeline' : 'Novo Pipeline'}
            </h1>
            <p className="text-sm text-gray-500">
              {isEditMode ? 'Modifique as configurações do pipeline' : 'Crie um novo pipeline YAML'}
            </p>
          </div>
        </div>

        <div className="flex items-center space-x-3">
          {/* Editor Mode Toggle */}
          <div className="flex rounded-lg bg-gray-100 dark:bg-gray-700 p-1">
            <button
              type="button"
              onClick={() => setEditorMode('form')}
              className={`flex items-center px-3 py-1.5 text-sm font-medium rounded-md transition-colors ${
                editorMode === 'form'
                  ? 'bg-white text-gray-900 shadow-sm dark:bg-gray-600 dark:text-white'
                  : 'text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200'
              }`}
            >
              <WrenchScrewdriverIcon className="h-4 w-4 mr-1" />
              Form Builder
            </button>
            <button
              type="button"
              onClick={() => setEditorMode('yaml')}
              className={`flex items-center px-3 py-1.5 text-sm font-medium rounded-md transition-colors ${
                editorMode === 'yaml'
                  ? 'bg-white text-gray-900 shadow-sm dark:bg-gray-600 dark:text-white'
                  : 'text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200'
              }`}
            >
              <CodeBracketIcon className="h-4 w-4 mr-1" />
              YAML Editor
            </button>
          </div>

          {isEditMode && (
            <button
              type="button"
              onClick={handleTestRun}
              disabled={!isValidYaml}
              className="inline-flex items-center px-3 py-2 border border-green-300 shadow-sm text-sm leading-4 font-medium rounded-md text-green-700 bg-green-50 hover:bg-green-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <PlayIcon className="h-4 w-4 mr-1" />
              Testar Pipeline
            </button>
          )}
        </div>
      </div>

      <form onSubmit={handleSubmit(onSubmit)} className="space-y-6">
        {/* Informações básicas */}
        <div className="bg-white shadow rounded-lg p-6">
          <h2 className="text-lg font-medium text-gray-900 mb-4">
            Informações Básicas
          </h2>
          
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label htmlFor="name" className="block text-sm font-medium text-gray-700">
                Nome do Pipeline *
              </label>
              <input
                {...register('name')}
                type="text"
                className="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                placeholder="meu-pipeline"
              />
              {errors.name && (
                <p className="mt-1 text-sm text-red-600">{errors.name.message}</p>
              )}
            </div>

            <div>
              <label htmlFor="cronExpression" className="block text-sm font-medium text-gray-700">
                Agendamento (Cron)
              </label>
              <input
                {...register('cronExpression')}
                type="text"
                className="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                placeholder="0 0 * * * (opcional)"
              />
            </div>
          </div>

          <div className="mt-4">
            <label htmlFor="description" className="block text-sm font-medium text-gray-700">
              Descrição
            </label>
            <textarea
              {...register('description')}
              rows={3}
              className="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
              placeholder="Descrição do pipeline..."
            />
          </div>

          <div className="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label htmlFor="tags" className="block text-sm font-medium text-gray-700">
                Tags
              </label>
              <input
                {...register('tags')}
                type="text"
                className="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                placeholder="tag1, tag2, tag3"
              />
            </div>

            <div className="flex items-center">
              <input
                {...register('isActive')}
                type="checkbox"
                className="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"
              />
              <label htmlFor="isActive" className="ml-2 block text-sm text-gray-900">
                Pipeline ativo
              </label>
            </div>
          </div>
        </div>

        {/* Editor YAML ou Form Builder */}
        <div className="bg-white shadow rounded-lg p-6">
          <div className="flex items-center justify-between mb-4">
            <h2 className="text-lg font-medium text-gray-900">
              {editorMode === 'form' ? 'Visual Pipeline Builder' : 'Definição YAML'}
            </h2>
            
            <div className="flex items-center space-x-2">
              {editorMode === 'yaml' && <CodeBracketIcon className="h-5 w-5 text-gray-400" />}
              {editorMode === 'form' && <WrenchScrewdriverIcon className="h-5 w-5 text-gray-400" />}
              {uploadedFileName && (
                <span className="text-sm text-gray-500">
                  Arquivo: {uploadedFileName}
                </span>
              )}
            </div>
          </div>

          {editorMode === 'form' ? (
            <div>
              <div className="grid grid-cols-1 lg:grid-cols-3 gap-6 h-[500px]">
                {/* Data Sources */}
                <div className="border border-gray-200 rounded-lg p-4">
                  <div className="flex items-center justify-between mb-3">
                    <h3 className="text-sm font-medium text-gray-900">Data Sources</h3>
                    <button
                      type="button"
                      onClick={() => openAddModal('source')}
                      className="inline-flex items-center px-2 py-1 text-xs font-medium rounded bg-blue-50 text-blue-700 hover:bg-blue-100 transition-colors"
                    >
                      <PlusIcon className="h-3 w-3 mr-1" />
                      Add Source
                    </button>
                  </div>
                  <div className="space-y-2 overflow-y-auto h-[400px]">
                    {pipeline.sources?.map((source, index) => (
                      <div key={index} className="bg-gray-50 p-3 rounded border">
                        <div className="flex items-center justify-between">
                          <div>
                            <p className="text-sm font-medium text-gray-900">{source.name}</p>
                            <p className="text-xs text-gray-500">{source.type}</p>
                          </div>
                          <div className="flex space-x-1">
                            <button
                              type="button"
                              onClick={() => editComponent('source', index)}
                              className="text-blue-600 hover:text-blue-800"
                            >
                              <PencilIcon className="h-4 w-4" />
                            </button>
                            <button
                              type="button"
                              onClick={() => removeComponent('source', index)}
                              className="text-red-600 hover:text-red-800"
                            >
                              <TrashIcon className="h-4 w-4" />
                            </button>
                          </div>
                        </div>
                      </div>
                    ))}
                    {(!pipeline.sources || pipeline.sources.length === 0) && (
                      <p className="text-sm text-gray-500 text-center py-8">
                        Nenhum data source configurado
                      </p>
                    )}
                  </div>
                </div>

                {/* Data Transformers */}
                <div className="border border-gray-200 rounded-lg p-4">
                  <div className="flex items-center justify-between mb-3">
                    <h3 className="text-sm font-medium text-gray-900">Data Transformers</h3>
                    <button
                      type="button"
                      onClick={() => openAddModal('transformer')}
                      className="inline-flex items-center px-2 py-1 text-xs font-medium rounded bg-green-50 text-green-700 hover:bg-green-100 transition-colors"
                    >
                      <PlusIcon className="h-3 w-3 mr-1" />
                      Add Transformer
                    </button>
                  </div>
                  <div className="space-y-2 overflow-y-auto h-[400px]">
                    {pipeline.transformers?.map((transformer, index) => (
                      <div key={index} className="bg-gray-50 p-3 rounded border">
                        <div className="flex items-center justify-between">
                          <div>
                            <p className="text-sm font-medium text-gray-900">{transformer.name}</p>
                            <p className="text-xs text-gray-500">{transformer.type}</p>
                          </div>
                          <div className="flex space-x-1">
                            <button
                              type="button"
                              onClick={() => editComponent('transformer', index)}
                              className="text-blue-600 hover:text-blue-800"
                            >
                              <PencilIcon className="h-4 w-4" />
                            </button>
                            <button
                              type="button"
                              onClick={() => removeComponent('transformer', index)}
                              className="text-red-600 hover:text-red-800"
                            >
                              <TrashIcon className="h-4 w-4" />
                            </button>
                          </div>
                        </div>
                      </div>
                    ))}
                    {(!pipeline.transformers || pipeline.transformers.length === 0) && (
                      <p className="text-sm text-gray-500 text-center py-8">
                        Nenhum transformer configurado
                      </p>
                    )}
                  </div>
                </div>

                {/* Data Destinations */}
                <div className="border border-gray-200 rounded-lg p-4">
                  <div className="flex items-center justify-between mb-3">
                    <h3 className="text-sm font-medium text-gray-900">Data Destinations</h3>
                    <button
                      type="button"
                      onClick={() => openAddModal('destination')}
                      className="inline-flex items-center px-2 py-1 text-xs font-medium rounded bg-purple-50 text-purple-700 hover:bg-purple-100 transition-colors"
                    >
                      <PlusIcon className="h-3 w-3 mr-1" />
                      Add Destination
                    </button>
                  </div>
                  <div className="space-y-2 overflow-y-auto h-[400px]">
                    {pipeline.destinations?.map((destination, index) => (
                      <div key={index} className="bg-gray-50 p-3 rounded border">
                        <div className="flex items-center justify-between">
                          <div>
                            <p className="text-sm font-medium text-gray-900">{destination.name}</p>
                            <p className="text-xs text-gray-500">{destination.type}</p>
                          </div>
                          <div className="flex space-x-1">
                            <button
                              type="button"
                              onClick={() => editComponent('destination', index)}
                              className="text-blue-600 hover:text-blue-800"
                            >
                              <PencilIcon className="h-4 w-4" />
                            </button>
                            <button
                              type="button"
                              onClick={() => removeComponent('destination', index)}
                              className="text-red-600 hover:text-red-800"
                            >
                              <TrashIcon className="h-4 w-4" />
                            </button>
                          </div>
                        </div>
                      </div>
                    ))}
                    {(!pipeline.destinations || pipeline.destinations.length === 0) && (
                      <p className="text-sm text-gray-500 text-center py-8">
                        Nenhum destination configurado
                      </p>
                    )}
                  </div>
                </div>
              </div>

              {/* Quick Actions */}
              <div className="mt-4 flex justify-between items-center">
                <button
                  type="button"
                  onClick={() => setEditorMode('yaml')}
                  className="inline-flex items-center px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50"
                >
                  <CodeBracketIcon className="h-4 w-4 mr-2" />
                  Ver YAML Gerado
                </button>
                
                <div className="text-sm text-gray-500">
                  {(pipeline.sources?.length || 0) + (pipeline.transformers?.length || 0) + (pipeline.destinations?.length || 0)} componentes configurados
                </div>
              </div>
            </div>
          ) : (
            /* YAML Editor */
            <div>
              {/* Templates e Upload */}
              <div className="mb-4 space-y-4">
                <div>
                  <label className="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Templates ou Upload
                  </label>
                  
                  <div className="flex flex-wrap gap-2 mb-4">
                    {Object.keys(PIPELINE_TEMPLATES).map((template) => (
                      <button
                        key={template}
                        type="button"
                        onClick={() => handleTemplateSelect(template as TemplateType)}
                        className={`px-3 py-1 text-sm rounded-md border transition-colors ${
                          selectedTemplate === template
                            ? 'bg-blue-100 border-blue-300 text-blue-700'
                            : 'bg-gray-50 border-gray-300 text-gray-700 hover:bg-gray-100'
                        }`}
                      >
                        {template.charAt(0).toUpperCase() + template.slice(1)}
                      </button>
                    ))}
                  </div>

                  <FileUpload onFileContent={handleFileUpload} />
                </div>
              </div>

              {/* Editor */}
              <YamlEditor
                value={yamlContent}
                onChange={setYamlContent}
                height="500px"
                onValidationChange={handleValidationChange}
              />

              {/* Validação */}
              <div className="mt-4">
                <ValidationResults
                  isValid={isValidYaml}
                  errors={validationErrors}
                />
              </div>
            </div>
          )}
        </div>

        {/* Actions */}
        <div className="flex justify-end space-x-3">
          <button
            type="button"
            onClick={() => router.push('/dashboard/pipelines')}
            className="px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
          >
            Cancelar
          </button>
          
          <button
            type="submit"
            disabled={!isValidYaml || isSaving}
            className="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            {isSaving ? 'Salvando...' : isEditMode ? 'Atualizar' : 'Criar Pipeline'}
          </button>
        </div>
      </form>

      {/* Modal para adicionar/editar componentes */}
      {showModal && modalType && (
        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
          <div className="bg-white rounded-lg max-w-md w-full p-6">
            <div className="flex items-center justify-between mb-4">
              <h3 className="text-lg font-medium text-gray-900">
                {editingIndex !== null ? 'Editar' : 'Adicionar'} {' '}
                {modalType === 'source' ? 'Data Source' : 
                 modalType === 'transformer' ? 'Transformer' : 'Destination'}
              </h3>
              <button
                onClick={() => setShowModal(false)}
                className="text-gray-400 hover:text-gray-600"
              >
                <XMarkIcon className="h-6 w-6" />
              </button>
            </div>

            <ComponentConfigModal
              type={modalType}
              editingComponent={editingIndex !== null ? 
                (modalType === 'source' ? pipeline.sources?.[editingIndex] :
                 modalType === 'transformer' ? pipeline.transformers?.[editingIndex] :
                 pipeline.destinations?.[editingIndex]) : undefined}
              onSave={(component) => {
                if (editingIndex !== null) {
                  updateComponent(modalType, editingIndex, component);
                } else {
                  addComponent(modalType, component);
                }
                setShowModal(false);
              }}
              onCancel={() => setShowModal(false)}
            />
          </div>
        </div>
      )}
    </div>
  );
}